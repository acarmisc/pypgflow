# PyPgFlow Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://pypgflow:pypgflow123@localhost:5432/pypgflow
POSTGRES_DB=pypgflow
POSTGRES_USER=pypgflow
POSTGRES_PASSWORD=pypgflow123

# PostgREST Configuration
PGRST_DB_URI=postgres://pypgflow:pypgflow123@postgres:5432/pypgflow
PGRST_DB_SCHEMAS=api
PGRST_DB_ANON_ROLE=anonymous
PGRST_JWT_SECRET=your-jwt-secret-here-change-in-production
PGRST_OPENAPI_SERVER_PROXY_URI=http://localhost:3000

# Development Settings
DEBUG=true
LOG_LEVEL=info

# Just Command Runner
# Install just: https://github.com/casey/just
# macOS: brew install just
# Linux: cargo install just  
# Windows: scoop install just